<div class="local-byblos-shared-with-me">
    <h3>{{# str }} nav_shared, local_byblos {{/ str }}</h3>

    {{# noresults }}
    <div class="alert alert-info">
        {{# str }} no_results, local_byblos {{/ str }}
    </div>
    {{/ noresults }}

    {{! Shared pages }}
    {{# haspages }}
    <h4 class="mt-4 mb-3">{{# str }} nav_pages, local_byblos {{/ str }}</h4>
    <div class="card-deck flex-wrap">
        {{# pages }}
        <div class="card mb-3" style="min-width: 280px; max-width: 350px;">
            <div class="card-body">
                <h5 class="card-title">
                    <a href="{{ viewurl }}">{{ title }}</a>
                </h5>
                {{# description }}
                <p class="card-text text-muted">{{ description }}</p>
                {{/ description }}
                <p class="card-text">
                    <small class="text-muted">
                        <i class="fa fa-user"></i> {{ owner }}
                    </small>
                </p>
                <p class="card-text">
                    <small class="text-muted">{{ timecreated }}</small>
                    <span class="badge badge-info ml-2">{{ status }}</span>
                </p>
            </div>
            <div class="card-footer">
                <a href="{{ viewurl }}" class="btn btn-sm btn-primary">
                    <i class="fa fa-eye"></i> {{# str }} action_preview, local_byblos {{/ str }}
                </a>
            </div>
        </div>
        {{/ pages }}
    </div>
    {{/ haspages }}

    {{! Shared collections }}
    {{# hascollections }}
    <h4 class="mt-4 mb-3">{{# str }} nav_collections, local_byblos {{/ str }}</h4>
    <div class="card-deck flex-wrap">
        {{# collections }}
        <div class="card mb-3" style="min-width: 280px; max-width: 350px;">
            <div class="card-body">
                <h5 class="card-title">
                    <a href="{{ viewurl }}">{{ title }}</a>
                </h5>
                {{# description }}
                <p class="card-text text-muted">{{ description }}</p>
                {{/ description }}
                <p class="card-text">
                    <small class="text-muted">
                        <i class="fa fa-user"></i> {{ owner }}
                    </small>
                </p>
                <p class="card-text">
                    <small class="text-muted">{{ timecreated }}</small>
                </p>
            </div>
            <div class="card-footer">
                <a href="{{ viewurl }}" class="btn btn-sm btn-primary">
                    <i class="fa fa-eye"></i> {{# str }} action_preview, local_byblos {{/ str }}
                </a>
            </div>
        </div>
        {{/ collections }}
    </div>
    {{/ hascollections }}
</div>
