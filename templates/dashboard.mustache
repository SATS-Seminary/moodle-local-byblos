{{!
    @template local_byblos/dashboard

    Portfolio dashboard — tabbed interface for pages, collections, artefacts.

    @package    local_byblos
    @copyright  2026 South African Theological Seminary
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
Example context (json):
    {
        "has_importmsgs": false,
        "importmsgs": "example",
        "tab_pages": "example",
        "tab_collections": "example",
        "tab_artefacts": "example",
        "tab_reviews": "example",
        "newpageurl": "#",
        "has_pages": false,
        "pages": "example",
        "viewurl": "#",
        "title": "example",
        "description": "example",
        "is_draft": false,
        "statuslabel": "example",
        "timecreated": "example",
        "previewurl": "#",
        "editurl": "#",
        "deleteurl": "#",
        "sesskey": "example",
        "id": "example",
        "actionurl": "#",
        "has_usergroups": false,
        "usergroups": "example",
        "name": "example",
        "coursecode": "example",
        "has_collections": false,
        "collections": "example",
        "is_group": false,
        "group_name": "example",
        "pagecount": "example",
        "is_creator": false,
        "newartefacturl": "#",
        "has_artefacts": false,
        "artefacts": "example",
        "typelabel": "example",
        "has_reviews": false,
        "reviews": "example",
        "assignmentname": "example",
        "revieweename": "example",
        "timeassigned": "example",
        "hasurl": "#",
        "reviewurl": "#"
    }
}}
<div class="byblos-dashboard">

    {{#has_importmsgs}}
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        {{#importmsgs}}
        <p class="mb-0">{{.}}</p>
        {{/importmsgs}}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    {{/has_importmsgs}}

    <ul class="nav nav-tabs mb-4" role="tablist">
        <li class="nav-item">
            <a class="nav-link {{#tab_pages}}active{{/tab_pages}}" data-bs-toggle="tab" href="#byblos-tab-pages" role="tab">
                <i class="fa fa-file-text-o"></i> {{#str}}tab_pages, local_byblos{{/str}}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link {{#tab_collections}}active{{/tab_collections}}" data-bs-toggle="tab" href="#byblos-tab-collections" role="tab">
                <i class="fa fa-folder-open-o"></i> {{#str}}tab_collections, local_byblos{{/str}}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link {{#tab_artefacts}}active{{/tab_artefacts}}" data-bs-toggle="tab" href="#byblos-tab-artefacts" role="tab">
                <i class="fa fa-puzzle-piece"></i> {{#str}}tab_artefacts, local_byblos{{/str}}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link {{#tab_reviews}}active{{/tab_reviews}}" data-bs-toggle="tab" href="#byblos-tab-reviews" role="tab">
                <i class="fa fa-comments-o"></i> {{#str}}tab_reviews, local_byblos{{/str}}
            </a>
        </li>
    </ul>

    <div class="tab-content">

        {{! ---- My Pages Tab ---- }}
        <div class="tab-pane fade {{#tab_pages}}show active{{/tab_pages}}" id="byblos-tab-pages" role="tabpanel">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4>{{#str}}tab_pages, local_byblos{{/str}}</h4>
                <a href="{{{newpageurl}}}" class="btn btn-primary">
                    <i class="fa fa-plus"></i> {{#str}}newpage, local_byblos{{/str}}
                </a>
            </div>
            {{#has_pages}}
            <div class="row">
                {{#pages}}
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">
                                <a href="{{{viewurl}}}">{{title}}</a>
                            </h5>
                            <p class="card-text text-muted small">{{{description}}}</p>
                            <span class="badge {{#is_draft}}badge-warning{{/is_draft}}{{^is_draft}}badge-success{{/is_draft}}">
                                {{statuslabel}}
                            </span>
                        </div>
                        <div class="card-footer bg-transparent">
                            <small class="text-muted">{{timecreated}}</small>
                            <div class="float-right">
                                <a href="{{{previewurl}}}" class="btn btn-sm btn-outline-secondary" target="_blank" rel="noopener" title="{{#str}}previewthispage, local_byblos{{/str}}">
                                    <i class="fa fa-eye"></i>
                                </a>
                                <a href="{{{editurl}}}" class="btn btn-sm btn-outline-primary" title="{{#str}}editthispage, local_byblos{{/str}}">
                                    <i class="fa fa-pencil"></i>
                                </a>
                                <form method="post" action="{{{deleteurl}}}" class="d-inline"
                                      onsubmit="return confirm('{{#str}}confirmdeletepage, local_byblos{{/str}}');">
                                    <input type="hidden" name="sesskey" value="{{sesskey}}">
                                    <input type="hidden" name="action" value="page">
                                    <input type="hidden" name="id" value="{{id}}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="{{#str}}deletethispage, local_byblos{{/str}}">
                                        <i class="fa fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
                {{/pages}}
            </div>
            {{/has_pages}}
            {{^has_pages}}
            <div class="alert alert-info">
                {{#str}}nopages, local_byblos{{/str}}
                <a href="{{{newpageurl}}}">{{#str}}newpage, local_byblos{{/str}}</a>
            </div>
            {{/has_pages}}
        </div>

        {{! ---- My Collections Tab ---- }}
        <div class="tab-pane fade {{#tab_collections}}show active{{/tab_collections}}" id="byblos-tab-collections" role="tabpanel">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4>{{#str}}tab_collections, local_byblos{{/str}}</h4>
            </div>

            {{! Inline new collection form }}
            <div class="card mb-4">
                <div class="card-body">
                    <h6>{{#str}}newcollection, local_byblos{{/str}}</h6>
                    <form method="post" action="{{{actionurl}}}" class="form-inline">
                        <input type="hidden" name="sesskey" value="{{sesskey}}">
                        <div class="form-group mr-2 mb-2">
                            <input type="text" class="form-control" name="coltitle" required
                                   placeholder="{{#str}}collectiontitle_placeholder, local_byblos{{/str}}">
                        </div>
                        <div class="form-group mr-2 mb-2">
                            <input type="text" class="form-control" name="coldesc"
                                   placeholder="{{#str}}collectiondesc, local_byblos{{/str}}">
                        </div>
                        {{#has_usergroups}}
                        <div class="form-group mr-2 mb-2">
                            <select class="form-control" name="colgroupid">
                                <option value="0">{{#str}}collection_group_personal, local_byblos{{/str}}</option>
                                {{#usergroups}}
                                <option value="{{id}}">{{name}}{{#coursecode}} — {{coursecode}}{{/coursecode}}</option>
                                {{/usergroups}}
                            </select>
                        </div>
                        {{/has_usergroups}}
                        <button type="submit" class="btn btn-primary mb-2">
                            <i class="fa fa-plus"></i> {{#str}}createcollection, local_byblos{{/str}}
                        </button>
                    </form>
                </div>
            </div>

            {{#has_collections}}
            <div class="row">
                {{#collections}}
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">
                                <a href="{{{viewurl}}}">{{title}}</a>
                                {{#is_group}}
                                <span class="badge badge-info ml-1" title="{{group_name}}">
                                    <i class="fa fa-users"></i> {{group_name}}
                                </span>
                                {{/is_group}}
                            </h5>
                            <p class="card-text text-muted small">{{{description}}}</p>
                            <span class="badge badge-secondary">{{pagecount}}</span>
                            {{#is_group}}
                            {{^is_creator}}
                            <span class="badge badge-light" title="{{#str}}collection_member_hint, local_byblos{{/str}}">
                                {{#str}}collection_member_badge, local_byblos{{/str}}
                            </span>
                            {{/is_creator}}
                            {{/is_group}}
                        </div>
                        <div class="card-footer bg-transparent">
                            <small class="text-muted">{{timecreated}}</small>
                            <div class="float-right">
                                <a href="{{{viewurl}}}" class="btn btn-sm btn-outline-primary">
                                    <i class="fa fa-eye"></i>
                                </a>
                                {{#is_creator}}
                                <form method="post" action="{{{deleteurl}}}" class="d-inline"
                                      onsubmit="return confirm('{{#str}}confirmdeletecollection, local_byblos{{/str}}');">
                                    <input type="hidden" name="sesskey" value="{{sesskey}}">
                                    <input type="hidden" name="action" value="collection">
                                    <input type="hidden" name="id" value="{{id}}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fa fa-trash"></i>
                                    </button>
                                </form>
                                {{/is_creator}}
                            </div>
                        </div>
                    </div>
                </div>
                {{/collections}}
            </div>
            {{/has_collections}}
            {{^has_collections}}
            <div class="alert alert-info">
                {{#str}}nocollections, local_byblos{{/str}}
            </div>
            {{/has_collections}}
        </div>

        {{! ---- My Artefacts Tab ---- }}
        <div class="tab-pane fade {{#tab_artefacts}}show active{{/tab_artefacts}}" id="byblos-tab-artefacts" role="tabpanel">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4>{{#str}}tab_artefacts, local_byblos{{/str}}</h4>
                <a href="{{{newartefacturl}}}" class="btn btn-primary">
                    <i class="fa fa-plus"></i> {{#str}}newartefact, local_byblos{{/str}}
                </a>
            </div>
            {{#has_artefacts}}
            <div class="row">
                {{#artefacts}}
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">
                                <a href="{{{viewurl}}}">{{title}}</a>
                            </h5>
                            <span class="badge badge-info">{{typelabel}}</span>
                            <p class="card-text text-muted small mt-2">{{{description}}}</p>
                        </div>
                        <div class="card-footer bg-transparent">
                            <small class="text-muted">{{timecreated}}</small>
                            <div class="float-right">
                                <a href="{{{editurl}}}" class="btn btn-sm btn-outline-primary">
                                    <i class="fa fa-pencil"></i>
                                </a>
                                <form method="post" action="{{{deleteurl}}}" class="d-inline"
                                      onsubmit="return confirm('{{#str}}confirmdeleteartefact, local_byblos{{/str}}');">
                                    <input type="hidden" name="sesskey" value="{{sesskey}}">
                                    <input type="hidden" name="action" value="artefact">
                                    <input type="hidden" name="id" value="{{id}}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fa fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
                {{/artefacts}}
            </div>
            {{/has_artefacts}}
            {{^has_artefacts}}
            <div class="alert alert-info">
                {{#str}}noartefacts, local_byblos{{/str}}
                <a href="{{{newartefacturl}}}">{{#str}}newartefact, local_byblos{{/str}}</a>
            </div>
            {{/has_artefacts}}
        </div>

        {{! ---- Reviews to do Tab ---- }}
        <div class="tab-pane fade {{#tab_reviews}}show active{{/tab_reviews}}" id="byblos-tab-reviews" role="tabpanel">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4>{{#str}}tab_reviews, local_byblos{{/str}}</h4>
            </div>
            {{#has_reviews}}
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>{{#str}}reviews_assignment, local_byblos{{/str}}</th>
                        <th>{{#str}}reviews_reviewee, local_byblos{{/str}}</th>
                        <th>{{#str}}reviews_assigned, local_byblos{{/str}}</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                {{#reviews}}
                    <tr>
                        <td>{{assignmentname}}</td>
                        <td>{{revieweename}}</td>
                        <td><small class="text-muted">{{timeassigned}}</small></td>
                        <td>
                            {{#hasurl}}
                            <a href="{{{reviewurl}}}" class="btn btn-sm btn-primary">
                                {{#str}}reviews_open, local_byblos{{/str}}
                            </a>
                            {{/hasurl}}
                        </td>
                    </tr>
                {{/reviews}}
                </tbody>
            </table>
            {{/has_reviews}}
            {{^has_reviews}}
            <div class="alert alert-info">
                {{#str}}reviews_empty, local_byblos{{/str}}
            </div>
            {{/has_reviews}}
        </div>

    </div>
</div>
