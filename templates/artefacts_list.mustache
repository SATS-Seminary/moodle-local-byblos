{{!
    @template local_byblos/artefacts_list

    Artefact list with type filter tabs.

    @package    local_byblos
    @copyright  2026 South African Theological Seminary
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
Example context (json):
    {
        "dashurl": "#",
        "newartefacturl": "#",
        "typefilters": "example",
        "active": "example",
        "url": "#",
        "label": "example",
        "has_artefacts": false,
        "artefacts": "example",
        "viewurl": "#",
        "title": "example",
        "typelabel": "example",
        "description": "example",
        "timecreated": "example",
        "editurl": "#",
        "deleteurl": "#",
        "sesskey": "example",
        "id": "example"
    }
}}
<div class="byblos-artefacts-list">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>{{#str}}myartefacts, local_byblos{{/str}}</h3>
        <div>
            <a href="{{{dashurl}}}" class="btn btn-outline-secondary btn-sm mr-2">
                <i class="fa fa-arrow-left"></i> {{#str}}dashboard, local_byblos{{/str}}
            </a>
            <a href="{{{newartefacturl}}}" class="btn btn-primary btn-sm">
                <i class="fa fa-plus"></i> {{#str}}newartefact, local_byblos{{/str}}
            </a>
        </div>
    </div>

    {{! Type filter pills }}
    <ul class="nav nav-pills mb-4">
        {{#typefilters}}
        <li class="nav-item">
            <a class="nav-link {{#active}}active{{/active}}" href="{{{url}}}">{{label}}</a>
        </li>
        {{/typefilters}}
    </ul>

    {{#has_artefacts}}
    <div class="row">
        {{#artefacts}}
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">
                        <a href="{{{viewurl}}}">{{title}}</a>
                    </h5>
                    <span class="badge badge-info">{{typelabel}}</span>
                    <p class="card-text text-muted small mt-2">{{{description}}}</p>
                </div>
                <div class="card-footer bg-transparent">
                    <small class="text-muted">{{timecreated}}</small>
                    <div class="float-right">
                        <a href="{{{editurl}}}" class="btn btn-sm btn-outline-primary">
                            <i class="fa fa-pencil"></i>
                        </a>
                        <form method="post" action="{{{deleteurl}}}" class="d-inline"
                              onsubmit="return confirm('{{#str}}confirmdeleteartefact, local_byblos{{/str}}');">
                            <input type="hidden" name="sesskey" value="{{sesskey}}">
                            <input type="hidden" name="action" value="artefact">
                            <input type="hidden" name="id" value="{{id}}">
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="fa fa-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        {{/artefacts}}
    </div>
    {{/has_artefacts}}
    {{^has_artefacts}}
    <div class="alert alert-info">
        {{#str}}noartefacts, local_byblos{{/str}}
        <a href="{{{newartefacturl}}}">{{#str}}newartefact, local_byblos{{/str}}</a>
    </div>
    {{/has_artefacts}}
</div>
