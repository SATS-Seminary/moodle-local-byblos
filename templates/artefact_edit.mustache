{{!
    @template local_byblos/artefact_edit

    Artefact create/edit form.

    @package    local_byblos
    @copyright  2026 South African Theological Seminary
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
Example context (json):
    {
        "is_edit": false,
        "actionurl": "#",
        "sesskey": "example",
        "id": "example",
        "types": [
            {"value": "text", "label": "Text", "selected": true},
            {"value": "file", "label": "File", "selected": false}
        ],
        "title": "example",
        "description": "example",
        "content": "example",
        "cancelurl": "#"
    }
}}
<div class="byblos-artefact-edit">

    <h3>
        {{#is_edit}}{{#str}}editartefact, local_byblos{{/str}}{{/is_edit}}
        {{^is_edit}}{{#str}}newartefact, local_byblos{{/str}}{{/is_edit}}
    </h3>

    <form method="post" action="{{{actionurl}}}">
        <input type="hidden" name="sesskey" value="{{sesskey}}">
        {{#is_edit}}
        <input type="hidden" name="id" value="{{id}}">
        {{/is_edit}}

        <div class="form-group">
            <label for="artefact-type">{{#str}}artefacttype, local_byblos{{/str}}</label>
            <select class="form-control" id="artefact-type" name="type" required>
                {{#types}}
                <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                {{/types}}
            </select>
        </div>

        <div class="form-group">
            <label for="artefact-title">{{#str}}artefacttitle, local_byblos{{/str}}</label>
            <input type="text" class="form-control" id="artefact-title" name="title"
                   value="{{title}}" required maxlength="255">
        </div>

        <div class="form-group">
            <label for="artefact-desc">{{#str}}artefactdesc, local_byblos{{/str}}</label>
            <textarea class="form-control" id="artefact-desc" name="description" rows="3">{{description}}</textarea>
        </div>

        <div class="form-group">
            <label for="artefact-content">{{#str}}artefactcontent, local_byblos{{/str}}</label>
            <textarea class="form-control" id="artefact-content" name="content" rows="8">{{content}}</textarea>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary">
                <i class="fa fa-save"></i> {{#str}}saveartefact, local_byblos{{/str}}
            </button>
            <a href="{{{cancelurl}}}" class="btn btn-outline-secondary ml-2">
                Cancel
            </a>
        </div>
    </form>
</div>
