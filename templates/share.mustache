Example context (json):
    {
        "itemtitle": "example",
        "hasshares": "example",
        "shares": "example",
        "sharetype": "example",
        "displayname": "example",
        "is_public": false,
        "publicurl": "#",
        "id": "example",
        "timecreated": "example",
        "actionurl": "#",
        "sesskey": "example",
        "itemid": "example",
        "itemtype": "example",
        "canpublic": "example",
        "has_users": false,
        "users": "example",
        "disabled": "example",
        "label": "example",
        "has_courses": false,
        "courses": "example",
        "has_groups": false,
        "groups": "example"
    }
}}

<div class="local-byblos-share">
    <h3>{{# str }} share_manage, local_byblos {{/ str }}: {{ itemtitle }}</h3>

    {{! Existing shares }}
    {{# hasshares }}
    <div class="card mb-4">
        <div class="card-header">
            <h4 class="mb-0">{{# str }} share_manage, local_byblos {{/ str }}</h4>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>{{# str }} sharetype_label, local_byblos {{/ str }}</th>
                        <th>{{# str }} name {{/ str }}</th>
                        <th>{{# str }} date {{/ str }}</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {{# shares }}
                    <tr>
                        <td>
                            <span class="badge badge-secondary">{{ sharetype }}</span>
                        </td>
                        <td>
                            {{ displayname }}
                            {{# is_public }}
                            <div class="mt-1">
                                <div class="input-group input-group-sm" style="max-width: 400px;">
                                    <input type="text" class="form-control" value="{{ publicurl }}" readonly id="public-url-{{ id }}">
                                    <div class="input-group-append">
                                        <button class="btn btn-outline-secondary"
                                                type="button"
                                                onclick="navigator.clipboard.writeText(document.getElementById('public-url-{{ id }}').value);"
                                                title="{{# str }} share_token_copied, local_byblos {{/ str }}">
                                            <i class="fa fa-copy"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            {{/ is_public }}
                        </td>
                        <td>{{ timecreated }}</td>
                        <td>
                            <form method="post" action="{{ actionurl }}" class="d-inline">
                                <input type="hidden" name="sesskey" value="{{ sesskey }}">
                                <input type="hidden" name="action" value="remove">
                                <input type="hidden" name="shareid" value="{{ id }}">
                                <input type="hidden" name="id" value="{{ itemid }}">
                                <input type="hidden" name="type" value="{{ itemtype }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('{{# str }} share_revoke_confirm, local_byblos {{/ str }}');">
                                    <i class="fa fa-times"></i> {{# str }} share_revoke, local_byblos {{/ str }}
                                </button>
                            </form>
                        </td>
                    </tr>
                    {{/ shares }}
                </tbody>
            </table>
        </div>
    </div>
    {{/ hasshares }}

    {{^ hasshares }}
    <div class="alert alert-info">
        {{# str }} no_results, local_byblos {{/ str }}
    </div>
    {{/ hasshares }}

    {{! Add share form }}
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">{{# str }} share_manage, local_byblos {{/ str }}</h4>
        </div>
        <div class="card-body">
            <form method="post" action="{{ actionurl }}">
                <input type="hidden" name="sesskey" value="{{ sesskey }}">
                <input type="hidden" name="action" value="add">
                <input type="hidden" name="id" value="{{ itemid }}">
                <input type="hidden" name="type" value="{{ itemtype }}">

                <div class="form-group">
                    <label for="byblos-sharetype">{{# str }} sharetype_label, local_byblos {{/ str }}</label>
                    <select class="form-control" name="sharetype" id="byblos-sharetype">
                        <option value="user">{{# str }} share_user, local_byblos {{/ str }}</option>
                        <option value="course">{{# str }} share_course, local_byblos {{/ str }}</option>
                        <option value="group">{{# str }} share_group, local_byblos {{/ str }}</option>
                        {{# canpublic }}
                        <option value="public">{{# str }} share_public, local_byblos {{/ str }}</option>
                        {{/ canpublic }}
                    </select>
                </div>

                <div class="form-group byblos-share-picker" data-sharetype="user">
                    <label>{{# str }} share_user, local_byblos {{/ str }}</label>
                    {{# has_users }}
                    <select class="form-control" id="byblos-sharevalue-user" data-name="sharevalue" disabled>
                        {{# users }}
                        <option value="{{ id }}" {{# disabled }}disabled{{/ disabled }}>
                            {{ label }}{{# disabled }} — {{# str }} share_already, local_byblos {{/ str }}{{/ disabled }}
                        </option>
                        {{/ users }}
                    </select>
                    {{/ has_users }}
                    {{^ has_users }}
                    <div class="alert alert-warning mb-0">{{# str }} share_no_users, local_byblos {{/ str }}</div>
                    {{/ has_users }}
                </div>

                <div class="form-group byblos-share-picker d-none" data-sharetype="course">
                    <label>{{# str }} share_course, local_byblos {{/ str }}</label>
                    {{# has_courses }}
                    <select class="form-control" id="byblos-sharevalue-course" data-name="sharevalue" disabled>
                        {{# courses }}
                        <option value="{{ id }}" {{# disabled }}disabled{{/ disabled }}>
                            {{ label }}{{# disabled }} — {{# str }} share_already, local_byblos {{/ str }}{{/ disabled }}
                        </option>
                        {{/ courses }}
                    </select>
                    {{/ has_courses }}
                    {{^ has_courses }}
                    <div class="alert alert-warning mb-0">{{# str }} share_no_courses, local_byblos {{/ str }}</div>
                    {{/ has_courses }}
                </div>

                <div class="form-group byblos-share-picker d-none" data-sharetype="group">
                    <label>{{# str }} share_group, local_byblos {{/ str }}</label>
                    {{# has_groups }}
                    <select class="form-control" id="byblos-sharevalue-group" data-name="sharevalue" disabled>
                        {{# groups }}
                        <option value="{{ id }}" {{# disabled }}disabled{{/ disabled }}>
                            {{ label }}{{# disabled }} — {{# str }} share_already, local_byblos {{/ str }}{{/ disabled }}
                        </option>
                        {{/ groups }}
                    </select>
                    {{/ has_groups }}
                    {{^ has_groups }}
                    <div class="alert alert-warning mb-0">{{# str }} share_no_groups, local_byblos {{/ str }}</div>
                    {{/ has_groups }}
                </div>

                {{# canpublic }}
                <div class="form-group byblos-share-picker d-none" data-sharetype="public">
                    <p class="text-muted mb-0">{{# str }} share_public_hint, local_byblos {{/ str }}</p>
                </div>
                {{/ canpublic }}

                <button type="submit" class="btn btn-primary">
                    <i class="fa fa-share-alt"></i> {{# str }} action_save, local_byblos {{/ str }}
                </button>
            </form>
        </div>
    </div>
</div>
